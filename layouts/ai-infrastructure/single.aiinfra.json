{
  "series": "Architecting AI Infrastructure",
  "author": "Frank Denneman",
  "site": "https://frankdenneman.nl",
  "series_url": "https://frankdenneman.nl/ai-infrastructure/",
  "description": "A practical series on how AI workloads behave on infrastructure, and how platforms should place and run them.",
  "articles": [
  {{- $pages := slice -}}
  {{- range site.RegularPages -}}
    {{- if and (eq .Type "posts") .Params.series -}}
      {{- if in .Params.series "Architecting AI Infrastructure" -}}
        {{- $pages = $pages | append . -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  {{- $pages = sort $pages "Params.series_order" "asc" -}}
  {{- $total := len $pages -}}
  {{- range $index, $p := $pages -}}
    {{- $prev := cond (gt $index 0) (index $pages (sub $index 1)) nil -}}
    {{- $next := cond (lt $index (sub $total 1)) (index $pages (add $index 1)) nil -}}
    {{- if $index }},{{ end }}
    {
      "part": {{ $p.Params.series_order }},
      "title": {{ $p.Title | jsonify }},
      "url": {{ $p.Permalink | jsonify }},
      "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
      "description": {{ $p.Description | default $p.Summary | plainify | htmlUnescape | jsonify }},
      "tags": {{ $p.Params.tags | default (slice) | jsonify }},
      "previous_part": {{ if $prev }}{{ $prev.Params.series_order }}{{ else }}null{{ end }},
      "previous_url": {{ if $prev }}{{ $prev.Permalink | jsonify }}{{ else }}null{{ end }},
      "next_part": {{ if $next }}{{ $next.Params.series_order }}{{ else }}null{{ end }},
      "next_url": {{ if $next }}{{ $next.Permalink | jsonify }}{{ else }}null{{ end }}
    }
  {{- end }}
  ]
}
